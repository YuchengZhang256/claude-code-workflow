{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "rate_table entry",
  "description": "Per-claim rate record produced by Phase B extractors (A, B) and consolidated by Phase B.2.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["claim_id", "label", "rate_dict"],
    "properties": {
      "claim_id":         { "type": "string", "pattern": "^RC[0-9]+$" },
      "label":            { "type": "string" },
      "kind":             { "enum": ["qualitative", "quantitative"] },
      "rate_dict": {
        "type": ["object", "null"],
        "description": "Dict of canonical variable → real-valued exponent. Missing variables default to 0.",
        "properties": {
          "log":          { "type": "number" },
          "K":            { "type": "number" },
          "N":            { "type": "number" },
          "M":            { "type": "number" },
          "n_m":          { "type": "number" },
          "lambda_min":   { "type": "number" },
          "underline_mu": { "type": "number" },
          "gamma_pil":    { "type": "number" },
          "l":            { "type": "number" },
          "Delta":        { "type": "number" },
          "c_row":        { "type": "number" },
          "delta_W":      { "type": "number" },
          "C_P":          { "type": "number" },
          "mu":           { "type": "number" },
          "epsilon":      { "type": "number" }
        },
        "additionalProperties": { "type": "number" }
      },
      "merge_mode":       { "enum": ["sequential", "triangle_sum", "concat_square", "union_bound"] },
      "contribution_mode":{ "enum": ["absolute", "delta"] },
      "excerpt":          { "type": "string", "description": "verbatim LaTeX of the stated rate, ≤200 chars" },
      "provenance": {
        "type": "object",
        "properties": {
          "file":  { "type": "string" },
          "line":  { "type": "integer" }
        }
      },
      "confidence":       { "type": "number", "minimum": 0, "maximum": 1 },
      "source":           { "enum": ["A", "B", "A=B", "A-only", "B-only",
                                     "dual-path", "DISAGREE_PENDING", "arbiter-A", "arbiter-B"] },
      "black_box_dependencies": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Parent claim_ids that are used as a black box in the proof body"
      },
      "note": { "type": "string" }
    }
  }
}
